# ===== Credenciais do app da Meta (Instagram API com Instagram Login) =====
# Crie um app em https://developers.facebook.com/apps  ->  produto "Instagram"
# Copie o "Instagram App ID" e o "Instagram App Secret" para cá.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# URL pública do seu site (sem barra no final).
# Em produção use o domínio da Vercel, ex: https://seu-app.vercel.app
# Em desenvolvimento local use http://localhost:3000
APP_URL=http://localhost:3000

# (Opcional) Chave da API da Anthropic para gerar recomendações com IA.
# Se ficar em branco, o app usa o motor de recomendações embutido (sem custo).
ANTHROPIC_API_KEY=
